# Environment configuration for AI Portal
# Copy this file to .env and fill in your values

# Database Configuration
DB_USER=aiportal
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=aiportal
DATABASE_URL=postgresql://aiportal:CHANGE_THIS_STRONG_PASSWORD@db:5432/aiportal

# NextAuth Configuration
NEXTAUTH_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_KEY
NEXTAUTH_URL=https://ai-portal.skillaro.eu

# Email for SSL Certificate (Let's Encrypt)
SSL_EMAIL=admin@skillaro.eu

# Optional: Add your other environment variables below
# OPENAI_API_KEY=
# PINECONE_API_KEY=
# etc...
